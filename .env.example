# ╔════════════════════════════════════════════════════════════╗
# ║                    ArrMada — .env                         ║
# ╚════════════════════════════════════════════════════════════╝

# ── Auth (OBLIGATOIRE) ────────────────────────────────────────
# Mot de passe pour accéder à ArrMada
ARRMADA_AUTH_SECRET=changeme_use_a_strong_password

# ── Database ──────────────────────────────────────────────────
# Par défaut : PostgreSQL intégrée (aucune config nécessaire)
# Pour utiliser une base PostgreSQL EXTERNE existante, décommenter :
# DATABASE_URL=postgresql+asyncpg://user:password@your-host:5432/arrmada
#
# Pour revenir à SQLite (dev uniquement) :
# DATABASE_URL=sqlite+aiosqlite:///./data/arrmada.db

# Mot de passe de la base PG intégrée (par défaut: arrmada)
POSTGRES_PASSWORD=arrmada

# ── Ports ─────────────────────────────────────────────────────
# Ports exposés (par défaut: 8420 backend, 3420 frontend)
# BACKEND_PORT=8420
# FRONTEND_PORT=3420

# ── CORS ──────────────────────────────────────────────────────
# Origines autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:3420

# ── Telegram (optionnel) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── TMDB (optionnel, pour recommandations & posters) ──────────
TMDB_API_KEY=

# ── Unraid (optionnel, pour discovery Docker mounts) ──────────
# UNRAID_URL=
# UNRAID_API_KEY=

# ╔════════════════════════════════════════════════════════════╗
# ║  Les clés API des services *arr (Sonarr, Radarr, etc.)   ║
# ║  sont configurées via le Setup Wizard au premier          ║
# ║  lancement et stockées CHIFFRÉES en base de données.     ║
# ║  ➜ Rien à mettre ici pour les services *arr !            ║
# ╚════════════════════════════════════════════════════════════╝
